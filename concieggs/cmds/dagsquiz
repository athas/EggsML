#!/usr/bin/env rash

linjer=>dagsquizinfo
>echo "Gæt hvilken af disse hændelser skete dags dato:"
<"${linjer}">cut -d: -f3-

:læsgæt
read gæt
EGGS_USER=>python -c "import os; print(os.getenv('EGGS_USER'))"
<${gæt}>grep -qiE '[0-9]+'
jz videre
>echo "${EGGS_USER}: Du skal skrive et heltal."
j læsgæt

:videre
<"${linjer}">grep -qE "^t:[^:]+:${gæt}"
jz korrektgæt

rigtig=<${linjer}>grep -E '^t:'
rigtig=<${rigtig}>cut -d: -f3
rigtig=<${rigtig}>cut -d. -f1
>echo "${EGGS_USER}: Dårligt!  Det var ${rigtig}!"
>wrongScoreInc ${EGGS_USER} "dagsquiz"
exit

:korrektgæt
>echo "${EGGS_USER}: Imponerende, det er rigtigt!"
>correctScoreInc ${EGGS_USER} "dagsquiz"
